            <h1 class="heading-primary h6">Cooking</h1>
            <div class="textimg"></div>
            </div>

        </section>
        <section class="about-main">
        <p class="about-text">I am a Undergrad engineer who has found what i wanted to do during this pandemic, which has given me lots of time to look at myself and crafting user experiences has caught my eye along with web developement and a bit of AI, but I have decided that UI/UX design is what i am going to purse the moment i learned about it and have dweled deeper into this ever since.</p>
        <div class="form-container u-mt-xl">
            <form action="https://formspree.io/f/xvolyjkk" method="post" class="u-mt-xl">
                <h3>Lets have a chat</h3>
                <input type="text" class="input" id="name" name="name" placeholder="Name" required>
                <input type="email" class="input" name="emailid" id="email" placeholder="Email">
                <input type="text" class="input" name="message" id="message" placeholder="Message">
                <button type="submit" class="btn btn-submit">Send</button>
            </form>
        </div>
    </section>
