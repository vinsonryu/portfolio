<body>
    <nav class="nav">
        <p class="nav-brand">Vinson</p>
        <ul class="nav-list">
            <li class="nav-item"><a href="/" class="nav-link">Work</a></li>
            <li class="nav-item"><a href="/about" class="nav-link">About</a></li>
            <li class="nav-item"><a href="#" class="nav-link">Resume</a></li>
        </ul>
